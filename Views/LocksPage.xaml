<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.LocksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <Grid Padding="16,8,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <Button x:Name="EllipsisButton" Visibility="Collapsed" Style="{StaticResource BreadcrumbEllipsisStyle}" Content="..." />
                <BreadcrumbBar x:Name="Breadcrumb" ItemClicked="Breadcrumb_ItemClicked">
                    <BreadcrumbBar.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" FontSize="28" FontWeight="SemiBold" />
                        </DataTemplate>
                    </BreadcrumbBar.ItemTemplate>
                </BreadcrumbBar>
            </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,0" Spacing="4">
            <InfoBar IsClosable="False" IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Severity="Error" />
        </StackPanel>

        <Border Grid.Row="2" Margin="0,12,0,0" Padding="12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="4">
            <StackPanel Spacing="8">
                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Add a new lock (scoped to this resource)" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Width="160" PlaceholderText="Lock name" Text="{x:Bind ViewModel.NewLockName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Width="140" SelectedIndex="{x:Bind ViewModel.SelectedLockLevelIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="CanNotDelete" />
                        <ComboBoxItem Content="ReadOnly" />
                    </ComboBox>
                    <Button Command="{x:Bind ViewModel.AddLockCommand}" Content="Add" Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
                <TextBox PlaceholderText="Notes (optional)" Text="{x:Bind ViewModel.NewLockNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <ListView Grid.Row="3" Margin="0,8,0,0" ItemsSource="{x:Bind ViewModel.Locks, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:LockEntry">
                    <Border Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                        <StackPanel>
                            <Grid Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Grid Visibility="{x:Bind IsConfirmingDelete, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" FontSize="16" VerticalAlignment="Center" Foreground="{ThemeResource SystemFillColorCautionBrush}" Glyph="{x:Bind LevelIcon, Mode=OneWay}" ToolTipService.ToolTip="{x:Bind Level, Mode=OneWay}" />
                                    <StackPanel Grid.Column="1" Margin="10,0,8,0" Spacing="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <Border Padding="5,1" Visibility="{x:Bind IsInherited, Converter={StaticResource BoolToVisibilityConverter}}" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                                                <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Inherited" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Notes, Mode=OneWay}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="EditLock_Click" Tag="{x:Bind}" Visibility="{x:Bind IsInherited, Converter={StaticResource InverseBoolToVisibilityConverter}}" ToolTipService.ToolTip="Edit"><FontIcon FontSize="14" Glyph="&#xE70F;" /></Button>
                                    <Button Grid.Column="3" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="DeleteLock_Click" Tag="{x:Bind}" Visibility="{x:Bind IsInherited, Converter={StaticResource InverseBoolToVisibilityConverter}}" ToolTipService.ToolTip="Delete"><FontIcon FontSize="14" Glyph="&#xE711;" /></Button>
                                </Grid>
                                <Grid Visibility="{x:Bind IsConfirmingDelete, Mode=OneWay}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource SystemFillColorCriticalBrush}"><Run Text="Delete &quot;" /><Run FontWeight="SemiBold" Text="{x:Bind Name}" /><Run Text="&quot;?" /></TextBlock>
                                    <Button Grid.Column="1" Margin="8,0,4,0" Click="ConfirmDeleteLock_Click" Content="Delete" Tag="{x:Bind}" Style="{ThemeResource AccentButtonStyle}" />
                                    <Button Grid.Column="2" Click="CancelDeleteLock_Click" Content="Cancel" Tag="{x:Bind}" />
                                </Grid>
                            </Grid>
                            <Grid Visibility="{x:Bind IsEditing, Mode=OneWay}">
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{x:Bind EditLevelIndex, Mode=TwoWay}">
                                        <ComboBoxItem Content="CanNotDelete" />
                                        <ComboBoxItem Content="ReadOnly" />
                                    </ComboBox>
                                    <TextBox PlaceholderText="Notes" Text="{x:Bind EditNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                        <Button Click="SaveEditLock_Click" Content="Save" Tag="{x:Bind}" Style="{ThemeResource AccentButtonStyle}" />
                                        <Button Click="CancelEditLock_Click" Content="Cancel" Tag="{x:Bind}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ProgressRing Grid.Row="3" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
    </Grid>
</Page>
