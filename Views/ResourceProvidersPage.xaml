<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourceProvidersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="16,8,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Breadcrumb -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <Button x:Name="EllipsisButton" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="4,0,12,0" VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold" Content="..." />
                <BreadcrumbBar x:Name="Breadcrumb" ItemClicked="Breadcrumb_ItemClicked">
                    <BreadcrumbBar.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" FontSize="28" FontWeight="SemiBold" />
                        </DataTemplate>
                    </BreadcrumbBar.ItemTemplate>
                </BreadcrumbBar>
            </StackPanel>

        <!-- Filters -->
        <StackPanel
            Grid.Row="1"
            Margin="0,12,0,0"
            Orientation="Horizontal"
            Spacing="8">
            <TextBox
                Width="300"
                VerticalAlignment="Bottom"
                AutomationProperties.Name="Search resource providers"
                PlaceholderText="Search by namespace..."
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox
                Width="200"
                Header="Status"
                AutomationProperties.Name="Filter by registration status"
                SelectedItem="{x:Bind ViewModel.StatusFilter, Mode=TwoWay}">
                <x:String>All</x:String>
                <x:String>Registered</x:String>
                <x:String>NotRegistered</x:String>
                <x:String>Registering</x:String>
                <x:String>Unregistering</x:String>
            </ComboBox>
            <ComboBox
                Width="220"
                Header="Policy"
                AutomationProperties.Name="Filter by registration policy"
                SelectedItem="{x:Bind ViewModel.PolicyFilter, Mode=TwoWay}">
                <x:String>All</x:String>
                <x:String>RegistrationRequired</x:String>
                <x:String>RegistrationFree</x:String>
            </ComboBox>
            <ToggleButton
                VerticalAlignment="Bottom"
                AutomationProperties.Name="Sort direction"
                Click="SortToggle_Click"
                IsChecked="{x:Bind ViewModel.SortAscending, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon FontSize="14" Glyph="&#xE8CB;" />
                    <TextBlock Text="A-Z" x:Name="SortLabel" />
                </StackPanel>
            </ToggleButton>
            <ProgressRing
                Width="20"
                Height="20"
                VerticalAlignment="Bottom"
                Margin="0,0,0,8"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <!-- Error -->
        <InfoBar
            Grid.Row="3"
            Margin="0,4,0,0"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <!-- Provider List -->
        <ListView
            Grid.Row="3"
            Margin="0,8,0,0"
            IsItemClickEnabled="True"
            ItemClick="Provider_ItemClick"
            ItemsSource="{x:Bind ViewModel.FilteredProviders, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ResourceProviderEntry">
                    <Border
                        Padding="16,12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Provider Namespace -->
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Namespace}"
                                        TextTrimming="CharacterEllipsis" />
                                    <FontIcon
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                        Glyph="&#xE73E;"
                                        Visibility="{x:Bind IsRegistered, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        AutomationProperties.Name="Registered" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind RegistrationPolicy}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{x:Bind ResourceTypeCount}" />
                                        <Run Text="resource types" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Updating indicator -->
                            <ProgressRing
                                Grid.Column="1"
                                Width="16"
                                Height="16"
                                Margin="4,0"
                                VerticalAlignment="Center"
                                IsActive="{x:Bind IsUpdating, Mode=OneWay}"
                                Visibility="{x:Bind IsUpdating, Mode=OneWay}" />

                            <!-- Register/Unregister Button -->
                            <Button
                                Grid.Column="2"
                                Margin="4,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Register provider"
                                Click="Register_Click"
                                Content="Register"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind IsRegistered, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                            <Button
                                Grid.Column="2"
                                Margin="4,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Unregister provider"
                                Click="Unregister_Click"
                                Content="Unregister"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind IsRegistered, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!-- Chevron -->
                            <FontIcon
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
