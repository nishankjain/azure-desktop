<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="16,8,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Breadcrumb -->
        <BreadcrumbBar x:Name="Breadcrumb" Grid.Row="0" ItemClicked="Breadcrumb_ItemClicked" />

        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,0"
            FontSize="28"
            FontWeight="SemiBold"
            Text="Resources" />

        <!-- Search + Filters -->
        <StackPanel
            Grid.Row="2"
            Margin="0,12,0,0"
            Orientation="Horizontal"
            Spacing="12">
            <TextBox
                Width="250"
                PlaceholderText="Search by name..."
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Type filter (multi-select flyout) -->
            <DropDownButton Content="Filter by type">
                <DropDownButton.Flyout>
                    <Flyout>
                        <ListView
                            x:Name="TypeFilterList"
                            Width="280"
                            MaxHeight="300"
                            ItemsSource="{x:Bind ViewModel.TypeFilters, Mode=OneWay}"
                            SelectionChanged="TypeFilterList_SelectionChanged"
                            SelectionMode="Multiple" />
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <!-- Location filter (multi-select flyout) -->
            <DropDownButton Content="Filter by location">
                <DropDownButton.Flyout>
                    <Flyout>
                        <ListView
                            x:Name="LocationFilterList"
                            Width="280"
                            MaxHeight="300"
                            ItemsSource="{x:Bind ViewModel.LocationFilters, Mode=OneWay}"
                            SelectionChanged="LocationFilterList_SelectionChanged"
                            SelectionMode="Multiple" />
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <Button Click="ClearFilters_Click" Content="Clear Filters" />
        </StackPanel>

        <!-- Sort buttons with indicator -->
        <StackPanel
            Grid.Row="3"
            Margin="0,8,0,8"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                VerticalAlignment="Center"
                Text="Sort by:" />
            <Button x:Name="SortNameButton" Click="SortByName_Click" FontSize="12" Padding="8,4" Content="Name ↑" />
            <Button x:Name="SortTypeButton" Click="SortByType_Click" FontSize="12" Padding="8,4" Content="Type" />
            <Button x:Name="SortLocationButton" Click="SortByLocation_Click" FontSize="12" Padding="8,4" Content="Location" />
            <ProgressRing
                Width="20"
                Height="20"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <InfoBar
            Grid.Row="4"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Warning" />

        <!-- Grouped resource list -->
        <ScrollViewer Grid.Row="5">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.GroupedResources, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ResourceTypeGroup">
                        <StackPanel Margin="0,0,0,16" Spacing="6">
                            <!-- Type section header -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,4">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind TypeName}" />
                                <Border
                                    Padding="6,2"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="8">
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Count}" />
                                </Border>
                            </StackPanel>

                            <!-- Resources in this type -->
                            <ItemsRepeater ItemsSource="{x:Bind Resources}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ResourceItem">
                                        <Border
                                            Margin="0,2"
                                            Padding="16"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            PointerPressed="Resource_PointerPressed"
                                            Tag="{x:Bind}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" VerticalAlignment="Center" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontSize="12"
                                                    Margin="8,0"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Text="{x:Bind Location}" />
                                                <FontIcon
                                                    Grid.Column="2"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Glyph="&#xE76C;"
                                                    VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
