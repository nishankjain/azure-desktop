<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourceProviderDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <ScrollViewer>
        <StackPanel Padding="16,8,40,40" Spacing="24">

            <!-- Breadcrumb -->
            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <Button x:Name="EllipsisButton" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="4,0,12,0" VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold" Content="..." />
                <BreadcrumbBar x:Name="Breadcrumb" ItemClicked="Breadcrumb_ItemClicked">
                    <BreadcrumbBar.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" FontSize="28" FontWeight="SemiBold" />
                        </DataTemplate>
                    </BreadcrumbBar.ItemTemplate>
                </BreadcrumbBar>
            </StackPanel>

            <!-- Title -->
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ProviderNamespace, Mode=OneWay}" />

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    AutomationProperties.Name="Register this provider"
                    Click="Register_Click"
                    Content="Register"
                    Style="{ThemeResource AccentButtonStyle}"
                    Visibility="{x:Bind IsNotRegistered, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button
                    AutomationProperties.Name="Unregister this provider"
                    Click="Unregister_Click"
                    Content="Unregister"
                    Visibility="{x:Bind IsRegistered, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ProgressRing
                    Width="20"
                    Height="20"
                    IsActive="{x:Bind IsUpdating, Mode=OneWay}"
                    Visibility="{x:Bind IsUpdating, Mode=OneWay}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Text="{x:Bind ErrorMessage, Mode=OneWay}"
                    Visibility="{x:Bind ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />
            </StackPanel>

            <!-- Overview Section -->
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Overview" />

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Registration Status" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind RegistrationState, Mode=OneWay}" />
                            <FontIcon
                                FontSize="14"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                Glyph="&#xE73E;"
                                Visibility="{x:Bind IsRegistered, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Registration Policy" />
                        <TextBlock Grid.Column="1" Text="{x:Bind RegistrationPolicy, Mode=OneWay}" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Resource Types" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ResourceTypeCount, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Resource Types Section -->
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Resource Type Details" />

            <AutoSuggestBox
                x:Name="ResourceTypeSearch"
                Width="400"
                HorizontalAlignment="Left"
                AutomationProperties.Name="Search and select a resource type"
                GotFocus="ResourceTypeSearch_GotFocus"
                PlaceholderText="Search resource types..."
                QueryIcon="Find"
                SuggestionChosen="ResourceTypeSearch_SuggestionChosen"
                TextChanged="ResourceTypeSearch_TextChanged" />

            <!-- Selected Resource Type Details -->
            <StackPanel x:Name="ResourceTypeDetails" Spacing="16" Visibility="Collapsed">

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="{x:Bind SelectedResourceTypeName, Mode=OneWay}" />
                    <TextBlock FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="Default API: " />
                        <Run Text="{x:Bind SelectedDefaultApiVersion, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <!-- 3-Column Layout -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Capabilities -->
                    <Border
                        Grid.Column="0"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Capabilities" />
                            <ListView
                                x:Name="CapabilitiesList"
                                MaxHeight="300"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock FontSize="12" Text="{x:Bind}" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- API Versions -->
                    <Border
                        Grid.Column="1"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="API Versions" />
                            <ListView
                                x:Name="ApiVersionsList"
                                MaxHeight="300"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock FontSize="12" Text="{x:Bind}" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Locations -->
                    <Border
                        Grid.Column="2"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Locations" />
                            <ListView
                                x:Name="LocationsList"
                                MaxHeight="300"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock FontSize="12" Text="{x:Bind}" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
