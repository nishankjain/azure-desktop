<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourceGroupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    mc:Ignorable="d"
    NavigationCacheMode="Disabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Text="Resource Groups" Margin="0,0,0,16" />

        <!-- Search + Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <TextBox Width="200" PlaceholderText="Search by name..." Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <DropDownButton Content="Location">
                <DropDownButton.Flyout>
                    <Flyout>
                        <ScrollViewer MaxHeight="300">
                            <ItemsRepeater x:Name="LocationFilterList" ItemsSource="{x:Bind ViewModel.LocationFilters, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <CheckBox Content="{x:Bind}" Checked="LocationFilter_Changed" Unchecked="LocationFilter_Changed" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <Button Click="ClearFilters_Click" Content="Clear" />
        </StackPanel>

        <!-- Sort -->
        <StackPanel Grid.Row="2" Margin="0,8,0,8" Orientation="Horizontal" Spacing="8">
            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Text="Sort:" />
            <Button x:Name="SortNameButton" Click="SortByName_Click" FontSize="12" Padding="8,4" Content="Name ↑" />
        </StackPanel>

        <!-- Error -->
        <InfoBar Grid.Row="3" IsClosable="False" IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Severity="Warning" />

        <!-- List -->
        <ListView
            Grid.Row="4"
            Margin="0,4,0,0"
            IsItemClickEnabled="True"
            ItemClick="ResourceGroupList_ItemClick"
            ItemsSource="{x:Bind ViewModel.FilteredResourceGroups, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <StaticResource ResourceKey="CardListViewItem" />
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ResourceGroupItem">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Width="24" Height="24" VerticalAlignment="Center">
                            <Image.Source>
                                <SvgImageSource UriSource="{x:Bind IconPath}" />
                            </Image.Source>
                        </Image>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Location}" />
                        </StackPanel>
                        <FontIcon Grid.Column="2" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE76C;" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
