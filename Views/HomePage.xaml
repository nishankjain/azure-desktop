<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <ScrollViewer Padding="40" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="800" Spacing="24">

            <TextBlock
                FontSize="32"
                FontWeight="SemiBold"
                Text="Azure Desktop" />

            <TextBlock
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap" />

            <Button
                MinWidth="200"
                Command="{x:Bind ViewModel.ToggleSignInCommand}"
                Content="{x:Bind ViewModel.SignInButtonText, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />

            <ProgressRing
                IsActive="{x:Bind ViewModel.IsSigningIn, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsSigningIn, Mode=OneWay}" />

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error" />

            <StackPanel
                Spacing="16"
                Visibility="{x:Bind ViewModel.IsAuthenticated, Mode=OneWay}">

                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Quick Actions" />

                <Grid ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Padding="20"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Click="Subscriptions_Click"
                        CornerRadius="4">
                        <StackPanel Spacing="8">
                            <FontIcon FontSize="28" Glyph="&#xE8CB;" />
                            <TextBlock FontWeight="SemiBold" Text="Subscriptions" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Browse all your Azure subscriptions"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
