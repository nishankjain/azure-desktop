<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourceGroupDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="16,8,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Breadcrumb -->
        <BreadcrumbBar x:Name="Breadcrumb" Grid.Row="0" ItemClicked="Breadcrumb_ItemClicked" />

        <!-- Header -->
        <StackPanel Grid.Row="1" Margin="0,8,0,16">
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="{x:Bind ViewModel.Name, Mode=OneWay}" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Left: Overview -->
            <ScrollViewer Grid.Column="0">
                <StackPanel Grid.Column="0" Spacing="16">

                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Overview" />

                    <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Resource Group Name" />
                                <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Name, Mode=OneWay}" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Location" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Location, Mode=OneWay}" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Resource ID" />
                                <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.ResourceId, Mode=OneWay}" TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: Resources -->
            <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Text="Resources" />
                        <ProgressRing Width="16" Height="16" IsActive="{x:Bind ResViewModel.IsLoading, Mode=OneWay}" Visibility="{x:Bind ResViewModel.IsLoading, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Width="200" PlaceholderText="Search by name..." Text="{x:Bind ResViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DropDownButton Content="Type">
                                <DropDownButton.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <ScrollViewer MaxHeight="300">
                                            <ItemsRepeater x:Name="TypeFilterList" ItemsSource="{x:Bind ResViewModel.TypeFilters, Mode=OneWay}">
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <CheckBox Content="{x:Bind}" Checked="TypeFilter_Changed" Unchecked="TypeFilter_Changed" />
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </ScrollViewer>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <DropDownButton Content="Location">
                                <DropDownButton.Flyout>
                                    <Flyout>
                                        <ScrollViewer MaxHeight="300">
                                            <ItemsRepeater x:Name="LocationFilterList" ItemsSource="{x:Bind ResViewModel.LocationFilters, Mode=OneWay}">
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <CheckBox Content="{x:Bind}" Checked="LocationFilter_Changed" Unchecked="LocationFilter_Changed" />
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </ScrollViewer>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <Button Click="ClearFilters_Click" Content="Clear" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,8,0,8" Orientation="Horizontal" Spacing="8">
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Text="Sort:" />
                        <Button x:Name="SortNameButton" Click="SortByName_Click" FontSize="12" Padding="8,4" Content="Name ↑" />
                        <Button x:Name="SortTypeButton" Click="SortByType_Click" FontSize="12" Padding="8,4" Content="Type" />
                        <Button x:Name="SortLocationButton" Click="SortByLocation_Click" FontSize="12" Padding="8,4" Content="Location" />
                    </StackPanel>

                    <InfoBar Grid.Row="3" IsClosable="False" IsOpen="{x:Bind ResViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ResViewModel.ErrorMessage, Mode=OneWay}" Severity="Warning" />

                    <ScrollViewer Grid.Row="4" Margin="0,4,0,0">
                        <ItemsRepeater ItemsSource="{x:Bind ResViewModel.GroupedResources, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:ResourceTypeGroup">
                                    <StackPanel Margin="0,0,0,12" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,4">
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DisplayName}" />
                                            <Border Padding="6,2" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8">
                                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Count}" />
                                            </Border>
                                        </StackPanel>
                                        <ItemsRepeater ItemsSource="{x:Bind Resources}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ResourceItem">
                                                    <Border Margin="0,2" Padding="12,10" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" PointerPressed="Resource_PointerPressed" Tag="{x:Bind}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Spacing="2">
                                                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Location}" />
                                                            </StackPanel>
                                                            <FontIcon Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE76C;" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>

        </Grid>
    </Grid>
</Page>
