<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <ScrollViewer>
        <StackPanel Padding="16,8,40,40" Spacing="24">

            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                <Button x:Name="EllipsisButton" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="4,0,12,0" VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold" Content="..." />
                <BreadcrumbBar x:Name="Breadcrumb" ItemClicked="Breadcrumb_ItemClicked">
                    <BreadcrumbBar.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}" FontSize="28" FontWeight="SemiBold" />
                        </DataTemplate>
                    </BreadcrumbBar.ItemTemplate>
                </BreadcrumbBar>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Image x:Name="ResourceIcon" Width="28" Height="28" VerticalAlignment="Center" />
                <TextBlock FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Text="{x:Bind ViewModel.Name, Mode=OneWay}" />
            </StackPanel>

            <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <InfoBar IsClosable="False" IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Severity="Error" />

            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Overview" />
            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                <StackPanel Spacing="16">
                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE8CB;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Name" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Name, Mode=OneWay}" VerticalAlignment="Center" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE74C;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Type" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.Type, Mode=OneWay}" VerticalAlignment="Center" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE81D;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Location" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.Location, Mode=OneWay}" VerticalAlignment="Center" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE71B;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Resource ID" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.ResourceId, Mode=OneWay}" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- App Gateway sections -->
            <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.IsAppGateway, Mode=OneWay}">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="SKU" />
                <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE8CB;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="SKU Name" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.SkuName, Mode=OneWay}" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE7AC;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="SKU Tier" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.SkuTier, Mode=OneWay}" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE95E;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Capacity" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.SkuCapacity, Mode=OneWay}" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xEA18;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Operational State" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.OperationalState, Mode=OneWay}" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE9F5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Provisioning State" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.ProvisioningState, Mode=OneWay}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
