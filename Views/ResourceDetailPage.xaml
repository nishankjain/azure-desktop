<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ResourceDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="16,8,40,40" Spacing="24">

            <BreadcrumbBar x:Name="Breadcrumb" Margin="0,0,0,16" ItemClicked="Breadcrumb_ItemClicked">
                <BreadcrumbBar.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" FontSize="24" />
                    </DataTemplate>
                </BreadcrumbBar.ItemTemplate>
            </BreadcrumbBar>

            <ProgressRing Width="20" Height="20" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <InfoBar IsClosable="False" IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Severity="Error" />

            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Overview" />
            <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="16">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Name" />
                        <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Name, Mode=OneWay}" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Type" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Type, Mode=OneWay}" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Location" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Location, Mode=OneWay}" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Resource ID" />
                        <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.ResourceId, Mode=OneWay}" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- App Gateway sections -->
            <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.IsAppGateway, Mode=OneWay}">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="SKU" />
                <Border Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="16">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="SKU Name" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SkuName, Mode=OneWay}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="SKU Tier" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SkuTier, Mode=OneWay}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Capacity" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SkuCapacity, Mode=OneWay}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Operational State" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.OperationalState, Mode=OneWay}" />
                        </Grid>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Provisioning State" />
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ProvisioningState, Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
