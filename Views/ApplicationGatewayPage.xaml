<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ApplicationGatewayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer Padding="40" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="800" Spacing="24">

            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Text="Application Gateway" />

            <!--  Create Form  -->
            <StackPanel
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Spacing="16">

                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Create Application Gateway" />

                <ComboBox
                    MinWidth="300"
                    DisplayMemberPath="Name"
                    Header="Subscription"
                    ItemsSource="{x:Bind ViewModel.Subscriptions, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedSubscription, Mode=TwoWay}" />

                <TextBox
                    MinWidth="300"
                    Header="Resource Group"
                    PlaceholderText="e.g. my-resource-group"
                    Text="{x:Bind ViewModel.ResourceGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    MinWidth="300"
                    Header="Gateway Name"
                    PlaceholderText="e.g. my-app-gateway"
                    Text="{x:Bind ViewModel.GatewayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    MinWidth="300"
                    Header="Location"
                    PlaceholderText="e.g. eastus"
                    Text="{x:Bind ViewModel.Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        MinWidth="160"
                        Command="{x:Bind ViewModel.CreateGatewayCommand}"
                        Content="Create Gateway"
                        Style="{StaticResource AccentButtonStyle}" />
                    <ProgressRing
                        Width="24"
                        Height="24"
                        IsActive="{x:Bind ViewModel.IsCreating, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Messages  -->
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error" />

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Success" />

            <!--  Existing Gateways  -->
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Existing Gateways" />
                    <Button Command="{x:Bind ViewModel.LoadGatewaysCommand}" Content="Refresh" />
                    <ProgressRing
                        Width="24"
                        Height="24"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                </StackPanel>

                <ListView ItemsSource="{x:Bind ViewModel.Gateways, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ApplicationGatewayItem">
                            <Border
                                Margin="0,4"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind Location}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="{x:Bind ResourceGroup}" />
                                    </StackPanel>
                                    <Border
                                        Grid.Column="1"
                                        Padding="8,4"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource SystemAccentColorLight2}"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="White"
                                            Text="{x:Bind State}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
