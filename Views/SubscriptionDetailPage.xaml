<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.SubscriptionDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="24">

            <!-- Breadcrumb -->
            <BreadcrumbBar x:Name="Breadcrumb" ItemClicked="Breadcrumb_ItemClicked" />

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock
                    AutomationProperties.AutomationId="SubscriptionDetailName"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.Subscription.Name, Mode=OneWay}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.Subscription.Id, Mode=OneWay}" />
            </StackPanel>

            <!-- Overview Section -->
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="Overview" />

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Subscription ID" />
                        <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.Id, Mode=OneWay}" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="State" />
                        <Border Grid.Column="1" Padding="8,4" HorizontalAlignment="Left" Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4">
                            <TextBlock FontSize="12" Foreground="White" Text="{x:Bind ViewModel.Subscription.State, Mode=OneWay}" />
                        </Border>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Tenant ID" />
                        <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.TenantId, Mode=OneWay}" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Authorization Source" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Subscription.AuthorizationSource, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Policies Section -->
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Subscription Policies" />

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Spending Limit" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Subscription.SpendingLimit, Mode=OneWay}" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Quota ID" />
                        <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.QuotaId, Mode=OneWay}" />
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Location Placement" />
                        <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.LocationPlacementId, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
