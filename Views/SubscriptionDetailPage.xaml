<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.SubscriptionDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Breadcrumb -->

        <!-- Title -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <Image Width="28" Height="28" VerticalAlignment="Center">
                <Image.Source>
                    <SvgImageSource UriSource="ms-appx:///Assets/Icons/subscriptions.svg" />
                </Image.Source>
            </Image>
            <TextBlock FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Text="{x:Bind ViewModel.Subscription.Name, Mode=OneWay}" />
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="16">

                <!-- Overview Section -->
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Overview" />

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8CB;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Subscription ID" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.Id, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xEA18;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="State" VerticalAlignment="Center" />
                                <Border Grid.Column="2" Padding="8,4" HorizontalAlignment="Left" Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4">
                                    <TextBlock FontSize="12" Foreground="White" Text="{x:Bind ViewModel.Subscription.State, Mode=OneWay}" />
                                </Border>
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE902;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Tenant ID" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.TenantId, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE72E;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Authorization Source" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.Subscription.AuthorizationSource, Mode=OneWay}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Policies Section -->
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Subscription Policies" />

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Spending Limit" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Subscription.SpendingLimit, Mode=OneWay}" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Quota ID" />
                                <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.QuotaId, Mode=OneWay}" />
                            </Grid>
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Location Placement" />
                                <TextBlock Grid.Column="1" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.Subscription.LocationPlacementId, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
    </Grid>
</Page>
