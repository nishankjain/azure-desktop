<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.AppGwSectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="16,8,40,40">
            <BreadcrumbBar x:Name="Breadcrumb" FontSize="14" ItemClicked="Breadcrumb_ItemClicked" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <TextBlock x:Name="SectionTitleText" FontSize="28" FontWeight="SemiBold" />
                <ProgressRing Width="24" Height="24" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            </StackPanel>

            <InfoBar Margin="0,8,0,0" IsClosable="False" IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Severity="Error" />
            <InfoBar Margin="0,4,0,0" IsClosable="True" IsOpen="{x:Bind ViewModel.SaveMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}" Message="{x:Bind ViewModel.SaveMessage, Mode=OneWay}" Severity="Success" />

            <!-- Saving indicator -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0" Visibility="{x:Bind ViewModel.IsSaving, Mode=OneWay}">
                <ProgressRing Width="20" Height="20" IsActive="True" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Saving changes to Azure... This may take a minute." />
            </StackPanel>

            <!-- Search box for collection sections -->
            <TextBox x:Name="SearchBox" Margin="0,8,0,0" Width="300" HorizontalAlignment="Left" PlaceholderText="Search by name..." TextChanged="SearchBox_TextChanged" Visibility="Collapsed" />

            <!-- Dynamic content area -->
            <StackPanel x:Name="ContentArea" Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
