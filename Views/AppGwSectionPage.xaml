<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.AppGwSectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:AzureDesktop.Controls"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Placeholder for section headers added by code-behind -->
        <StackPanel x:Name="HeaderArea" Grid.Row="0" />

        <!-- Content area: switches between property card and data table -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <!-- Property card (Overview, Configuration, WAF) -->
            <ScrollViewer x:Name="PropertyCardArea" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PropertyCardStack" Spacing="8" />
            </ScrollViewer>

            <!-- Data table (all list sections) -->
            <controls:DataTableControl x:Name="SectionTable" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
