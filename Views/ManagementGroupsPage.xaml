<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AzureDesktop.Views.ManagementGroupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    Loaded="Page_Loaded"
    mc:Ignorable="d" NavigationCacheMode="Disabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="20"
            FontWeight="SemiBold"
            Text="Browse Azure" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,16"
            Orientation="Horizontal"
            Spacing="12">
            <Button Command="{x:Bind ViewModel.LoadCommand}" Content="Refresh" />
            <ProgressRing
                Width="24"
                Height="24"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <InfoBar
            Grid.Row="2"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Warning" />

        <!-- Management Groups list (shown when user has MG permissions) -->
        <ListView
            Grid.Row="3"
            IsItemClickEnabled="True"
            ItemClick="ManagementGroupList_ItemClick"
            ItemsSource="{x:Bind ViewModel.ManagementGroups, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.IsFlatMode, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <ListView.ItemContainerStyle>
                            <StaticResource ResourceKey="CardListViewItem" />
                        </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ManagementGroupItem">
                    <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="ID:" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Id}" />
                                </StackPanel>
                            </StackPanel>
                            <FontIcon
                                Grid.Column="1"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE76C;"
                                VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Flat subscriptions list (shown when user lacks MG permissions) -->
        <ListView
            Grid.Row="3"
            IsItemClickEnabled="True"
            ItemClick="SubscriptionList_ItemClick"
            ItemsSource="{x:Bind ViewModel.FlatSubscriptions, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.IsFlatMode, Mode=OneWay}">
            <ListView.ItemContainerStyle>
                            <StaticResource ResourceKey="CardListViewItem" />
                        </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:SubscriptionItem">
                    <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="Subscription ID:" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Id}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                                <Border
                                    Padding="8,4"
                                    Background="{ThemeResource SystemAccentColorLight2}"
                                    CornerRadius="4">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="White"
                                        Text="{x:Bind State}" />
                                </Border>
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE76C;" />
                            </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
