<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="AzureDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AzureDesktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Azure Desktop"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar with back + home buttons -->
        <Grid x:Name="AppTitleBar" Height="48" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                Width="44"
                Height="32"
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                AutomationProperties.Name="Back"
                Background="Transparent"
                BorderThickness="0"
                Click="BackButton_Click"
                Visibility="Collapsed">
                <FontIcon FontSize="12" Glyph="&#xE72B;" />
            </Button>
            <Button
                x:Name="HomeButton"
                Grid.Column="1"
                Width="44"
                Height="32"
                VerticalAlignment="Center"
                AutomationProperties.Name="Home"
                Background="Transparent"
                BorderThickness="0"
                Click="HomeButton_Click"
                ToolTipService.ToolTip="Home">
                <FontIcon FontSize="14" Glyph="&#xE80F;" />
            </Button>
            <Button
                x:Name="PaneToggleButton"
                Grid.Column="2"
                Width="44"
                Height="32"
                Margin="0"
                VerticalAlignment="Center"
                AutomationProperties.Name="Toggle navigation"
                Background="Transparent"
                BorderThickness="0"
                Click="PaneToggle_Click"
                Visibility="Collapsed">
                <FontIcon FontSize="16" Glyph="&#xE700;" />
            </Button>
        </Grid>

        <!-- Navigation view (no back button, no header) -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="NavView_ItemInvoked"
            OpenPaneLength="240"
            PaneDisplayMode="Left">

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
