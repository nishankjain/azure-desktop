<UserControl
    x:Class="AzureDesktop.Controls.BreadcrumbControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
        <Button x:Name="EllipsisButton"
                Visibility="Collapsed"
                Style="{StaticResource BreadcrumbEllipsisStyle}"
                Content="···" />
        <BreadcrumbBar x:Name="Breadcrumb"
                       ItemClicked="Breadcrumb_ItemClicked">
            <BreadcrumbBar.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock Text="{x:Bind}" FontSize="24" FontWeight="SemiBold" LineHeight="24" Margin="0,-3,0,0" />
                </DataTemplate>
            </BreadcrumbBar.ItemTemplate>
        </BreadcrumbBar>
    </StackPanel>

</UserControl>
