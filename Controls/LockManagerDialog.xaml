<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="AzureDesktop.Controls.LockManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    Title="Manage Resource Locks"
    CloseButtonText="Close"
    DefaultButton="Close"
    mc:Ignorable="d">

    <StackPanel MinWidth="480" MaxWidth="560" Spacing="12">

        <!-- Loading / Saving -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <ProgressRing
                Width="16"
                Height="16"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <ProgressRing
                Width="16"
                Height="16"
                IsActive="{x:Bind ViewModel.IsSaving, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsSaving, Mode=OneWay}" />
        </StackPanel>

        <!-- Success message -->
        <InfoBar
            IsClosable="True"
            IsOpen="{x:Bind ViewModel.SuccessMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
            Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
            Severity="Success" />

        <!-- Error message -->
        <InfoBar
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <!-- Add new lock (static, always visible) -->
        <Border
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="4">
            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Add a new lock (scoped to this resource)" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox
                        Width="160"
                        PlaceholderText="Lock name"
                        Text="{x:Bind ViewModel.NewLockName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox
                        Width="140"
                        SelectedIndex="{x:Bind ViewModel.SelectedLockLevelIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="CanNotDelete" />
                        <ComboBoxItem Content="ReadOnly" />
                    </ComboBox>
                    <Button
                        Command="{x:Bind ViewModel.AddLockCommand}"
                        Content="Add"
                        Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
                <TextBox
                    PlaceholderText="Notes (optional)"
                    Text="{x:Bind ViewModel.NewLockNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- Existing locks (scrollable) -->
        <ListView
            MaxHeight="320"
            ItemsSource="{x:Bind ViewModel.Locks, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:LockEntry">
                    <Border
                        Padding="12,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel>

                        <!-- Normal view (not editing, not confirming delete) -->
                        <Grid Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Grid Visibility="{x:Bind IsConfirmingDelete, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Lock type icon -->
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="16"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                    Glyph="{x:Bind LevelIcon, Mode=OneWay}"
                                    ToolTipService.ToolTip="{x:Bind Level, Mode=OneWay}" />

                                <!-- Name + notes -->
                                <StackPanel Grid.Column="1" Margin="10,0,8,0" Spacing="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Border
                                            Padding="5,1"
                                            Visibility="{x:Bind IsInherited, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="10"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="Inherited" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Notes, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="1" />
                                </StackPanel>

                                <!-- Edit button -->
                                <Button
                                    Grid.Column="2"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="EditLock_Click"
                                    Tag="{x:Bind}"
                                    Visibility="{x:Bind IsInherited, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    ToolTipService.ToolTip="Edit lock">
                                    <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                </Button>

                                <!-- Delete button -->
                                <Button
                                    Grid.Column="3"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="DeleteLock_Click"
                                    Tag="{x:Bind}"
                                    Visibility="{x:Bind IsInherited, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    ToolTipService.ToolTip="Delete lock">
                                    <FontIcon FontSize="14" Glyph="&#xE711;" />
                                </Button>
                            </Grid>

                            <!-- Confirm delete -->
                            <Grid Visibility="{x:Bind IsConfirmingDelete, Mode=OneWay}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                    <Run Text="Delete &quot;" /><Run FontWeight="SemiBold" Text="{x:Bind Name}" /><Run Text="&quot;?" />
                                </TextBlock>
                                <Button
                                    Grid.Column="1"
                                    Margin="8,0,4,0"
                                    Click="ConfirmDelete_Click"
                                    Content="Delete"
                                    Tag="{x:Bind}"
                                    Style="{ThemeResource AccentButtonStyle}" />
                                <Button
                                    Grid.Column="2"
                                    Click="CancelDelete_Click"
                                    Content="Cancel"
                                    Tag="{x:Bind}" />
                            </Grid>
                        </Grid>

                        <!-- Edit view -->
                        <Grid Visibility="{x:Bind IsEditing, Mode=OneWay}">
                            <StackPanel Spacing="6">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                <ComboBox
                                    HorizontalAlignment="Stretch"
                                    SelectedIndex="{x:Bind EditLevelIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="CanNotDelete" />
                                    <ComboBoxItem Content="ReadOnly" />
                                </ComboBox>
                                <TextBox
                                    PlaceholderText="Notes"
                                    Text="{x:Bind EditNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                    <Button
                                        Click="SaveEdit_Click"
                                        Content="Save"
                                        Tag="{x:Bind}"
                                        Style="{ThemeResource AccentButtonStyle}" />
                                    <Button
                                        Click="CancelEdit_Click"
                                        Content="Cancel"
                                        Tag="{x:Bind}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
