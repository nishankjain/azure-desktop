<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="AzureDesktop.Controls.TagManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureDesktop.ViewModels"
    Title="Manage Tags"
    CloseButtonText="Close"
    DefaultButton="Close"
    mc:Ignorable="d">

    <StackPanel MinWidth="480" MaxWidth="560" Spacing="12">

        <!-- Loading -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <ProgressRing
                Width="16"
                Height="16"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <!-- Error message -->
        <InfoBar
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <!-- Add new tag (static, always visible) -->
        <Border
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="4">
            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Add a new tag" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox
                        Width="160"
                        PlaceholderText="Key"
                        Text="{x:Bind ViewModel.NewTagKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox
                        Width="200"
                        PlaceholderText="Value"
                        Text="{x:Bind ViewModel.NewTagValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Command="{x:Bind ViewModel.AddTagCommand}"
                        Content="Add"
                        Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Existing tags (scrollable) -->
        <ListView
            MaxHeight="320"
            ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TagEntry">
                    <Border
                        Padding="12,10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <StackPanel>

                            <!-- Normal view -->
                            <Grid Visibility="{x:Bind IsEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Grid Visibility="{x:Bind IsConfirmingDelete, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Key, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="12,0,8,0"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Value, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                    <Button
                                        Grid.Column="2"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="EditTag_Click"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Edit tag">
                                        <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                    </Button>
                                    <Button
                                        Grid.Column="3"
                                        Width="32"
                                        Height="32"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="DeleteTag_Click"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Delete tag">
                                        <FontIcon FontSize="14" Glyph="&#xE711;" />
                                    </Button>
                                </Grid>

                                <!-- Confirm delete -->
                                <Grid Visibility="{x:Bind IsConfirmingDelete, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                        <Run Text="Delete &quot;" /><Run FontWeight="SemiBold" Text="{x:Bind Key, Mode=OneWay}" /><Run Text="&quot;?" />
                                    </TextBlock>
                                    <Button
                                        Grid.Column="1"
                                        Margin="8,0,4,0"
                                        Click="ConfirmDelete_Click"
                                        Content="Delete"
                                        Tag="{x:Bind}"
                                        Style="{ThemeResource AccentButtonStyle}" />
                                    <Button
                                        Grid.Column="2"
                                        Click="CancelDelete_Click"
                                        Content="Cancel"
                                        Tag="{x:Bind}" />
                                </Grid>
                            </Grid>

                            <!-- Edit view -->
                            <Grid Visibility="{x:Bind IsEditing, Mode=OneWay}">
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Key, Mode=OneWay}" />
                                    <TextBox
                                        PlaceholderText="Value"
                                        Text="{x:Bind EditValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                        <Button
                                            Click="SaveEdit_Click"
                                            Content="Save"
                                            Tag="{x:Bind}"
                                            Style="{ThemeResource AccentButtonStyle}" />
                                        <Button
                                            Click="CancelEdit_Click"
                                            Content="Cancel"
                                            Tag="{x:Bind}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
